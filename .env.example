# 复制本文件为 .env 后按需修改。
# PowerShell 示例：Copy-Item .env.example .env

# =====================
# Docker 服务自身配置
# =====================

# 宿主机暴露端口。容器内固定为 8000。
JM_SERVICE_PORT=8000

# 后台下载任务并发数。建议 1-3，过高会增加网络和目标站压力。
JM_SERVICE_WORKERS=2

# 默认输出格式：pdf / zip / raw / original。
# pdf：默认值，下载后导出 PDF，再把 PDF 打包成 zip 返回。
# zip/raw/original：保留原始下载图片文件，并打包成 zip 返回。
JM_DEFAULT_OUTPUT_FORMAT=pdf

# =====================
# 网络代理与登录
# =====================

# 容器内访问外网时使用的代理。留空表示不使用代理。
# Docker Desktop 的 Windows/macOS 宿主机代理通常写 host.docker.internal。
# 示例：JM_PROXY=http://host.docker.internal:7890
JM_PROXY=

# 禁漫/JM 网站账号。留空表示不登录，普通查询/下载通常仍可用。
# 如果填写，JM_USERNAME 和 JM_PASSWORD 必须同时填写。
JM_USERNAME=
JM_PASSWORD=

# =====================
# jmcomic Client 配置
# =====================

# 客户端实现：api / html。
# api：默认，移动端接口，兼容性通常更好。
# html：网页端接口，部分搜索/分类能力可能更接近网页，但更容易受地区和风控影响。
JM_CLIENT_IMPL=api

# Client 元数据缓存。
# 留空/null/false：关闭；true：开启 option 级缓存；也可填 level_option / level_client。
JM_CLIENT_CACHE=

# 请求失败重试次数。
JM_CLIENT_RETRY_TIMES=5

# 单次请求超时时间，单位秒。
JM_REQUEST_TIMEOUT=20

# curl_cffi 浏览器指纹。常用：chrome。
JM_REQUEST_IMPERSONATE=chrome

# =====================
# 下载行为配置
# =====================

# 已存在同路径文件时是否跳过下载。
# 注意：当前服务每个任务使用独立目录，所以不同任务之间默认不会复用文件。
JM_DOWNLOAD_CACHE=true

# 是否还原 JM 混淆图片。通常保持 true。
JM_IMAGE_DECODE=true

# 图片输出后缀。留空表示保留原后缀；可填 .jpg / .png / .webp。
JM_IMAGE_SUFFIX=

# 同时下载图片数量。
JM_IMAGE_THREADS=20

# 同时下载章节数量。
JM_PHOTO_THREADS=4

# =====================
# 保存目录规则
# =====================

# jmcomic 目录规则 DSL。常用字段可参考 assets/docs/sources/option_file_syntax.md。
# 默认：基础目录 / 作者 / 本子标题 / 章节序号。
JM_DIR_RULE=Bd_Aauthor_Atitle_Pindex

# 繁简转换：zh-cn / zh-tw / 留空。
JM_NORMALIZE_ZH=zh-cn

